html
  background: #f5f5f7;
  -webkit-text-size-adjust: 100%;

body
  color: #1d1d1f;
  background: #f5f5f7;
  font-family: -apple-system, BlinkMacSystemFont, "SF Pro Text", "Segoe UI", sans-serif;
  letter-spacing: 0;

.theme-container
  background:
    linear-gradient(180deg, rgba(255, 255, 255, 0.78), rgba(245, 245, 247, 0.96) 18rem),
    #f5f5f7;

.navbar
  background: rgba(255, 255, 255, 0.82);
  border-bottom: 1px solid rgba(0, 0, 0, 0.08);
  backdrop-filter: saturate(180%) blur(18px);
  -webkit-backdrop-filter: saturate(180%) blur(18px);
  .site-name
    color: #1d1d1f;
    font-weight: 800;
  .links
    background: transparent;

.sidebar
  background: rgba(255, 255, 255, 0.76);
  border-right: 1px solid rgba(0, 0, 0, 0.08);
  backdrop-filter: saturate(180%) blur(18px);
  -webkit-backdrop-filter: saturate(180%) blur(18px);

.content__default:not(.custom)
  max-width: 820px;
  padding-top: 3.8rem;
  color: #1d1d1f;
  line-height: 1.78;

.page
  padding-bottom: 3rem;

.page-edit,
.page-nav
  max-width: 820px;

h1,
h2,
h3,
h4
  color: #1d1d1f;
  letter-spacing: 0;

h1
  font-size: 2.2rem;
  line-height: 1.15;

h2
  padding-bottom: 0.35rem;
  border-bottom: 1px solid rgba(0, 0, 0, 0.08);

a
  color: #0071e3;

blockquote
  color: #515154;
  background: rgba(255, 255, 255, 0.74);
  border-left: 4px solid #0071e3;
  border-radius: 10px;
  padding: 0.75rem 1rem;

table
  display: table;
  width: 100%;
  overflow: hidden;
  background: rgba(255, 255, 255, 0.86);
  border-radius: 12px;

tr:nth-child(2n)
  background: rgba(0, 0, 0, 0.025);

code
  color: #1d1d1f;
  background: rgba(0, 0, 0, 0.06);

p
  text-indent: 2em;

table
ol
ul
  margin-left: 2em;

thead
  display: none;

.show_table_head thead
  display: table-header-group;

li p
  text-indent: 0;

.description
  text-indent: 0;

.action
  text-indent: 0;

h3
  line-height: 1.7;

.home_author
  max-width: 820px;
  margin: 0 auto 1rem;
  color: #515154;
  font-size: 1rem;
  font-weight: 500;
  line-height: 1.85;

.preface_author
  display: flex;
  justify-content: flex-end;
  &.preface_author_title
    margin-top: 4rem;
  &.preface_author_signature
    font-size: 1.35rem;
    font-weight: bold;

.contents_class
  .content__default
    ul
      margin-left: 0;
    .header-anchor
      display: none;
    a
      &:link
      &:active
      &:visited
      &:hover
        color: #2c3e50;

.home .hero
  display: none;

.home .features
  border-top: 0;

.home .theme-default-content
  max-width: 1000px;

.home .content__default
  padding-top: 4.6rem;

@media (min-width: 720px)
  .content__default:not(.custom)
    padding-left: 2rem;
    padding-right: 2rem;

@media (max-width: 719px)
  .navbar
    height: 3.6rem;
  .sidebar
    top: 3.6rem;
  .content__default:not(.custom)
    padding: 3.8rem 1.5rem 2rem;
  .home .content__default
    padding-top: 3.8rem;
  h1
    font-size: 1.85rem;
  h2
    font-size: 1.35rem;
  table
    display: block;
    overflow-x: auto;
    -webkit-overflow-scrolling: touch;
